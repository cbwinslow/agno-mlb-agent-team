# ============================================================
# agno-mlb-agent-team — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ============================================================

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- LiteLLM Proxy (optional) ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=cbwinslow/agno-mlb-agent-team

# --- Baseball Data ---
# Path to your local Retrosheet / Statcast data repo
MLB_REPO_PATH=/home/your_user/mlb-baseball

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/agno_mlb
# DuckDB alternative (no server required)
DUCKDB_PATH=./data/mlb.duckdb

# --- Vector Store (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Agno Runtime ---
AGNO_PORT=7777
AGNO_HOST=0.0.0.0
AGNO_LOG_LEVEL=INFO

# --- OpenTelemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agno-mlb-agent-team
